{
  "name": "dream-os-backend",
  "version": "0.11.1-alpha",
  "description": "WhatsApp-first chief of staff — for wedding vendors (dream-os) and brides (dream-wedding). Monorepo: two Railway services share this codebase; each picks its entry point via the start script.",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "start:bride": "node src/brideIndex.js",
    "dev": "node --watch src/index.js",
    "dev:bride": "node --watch src/brideIndex.js",
    "build": "npm run build:engine",
    "build:engine": "tsc -p src/engine/tsconfig.json",
    "typecheck:engine": "tsc -p src/engine/tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.97.0",
    "@google/genai": "^2.2.0",
    "@supabase/supabase-js": "^2.45.0",
    "cloudinary": "^2.10.0",
    "cors": "^2.8.5",
    "cookie-parser": "^1.4.7",
    "express": "^4.21.0",
    "node-cron": "^4.2.1",
    "pdfkit": "^0.18.0",
    "qrcode": "^1.5.4",
    "bcryptjs": "^2.4.3",
    "twilio": "^5.3.0",
    "ws": "^8.20.1",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "@types/node": "^20.17.0",
    "@types/express": "^4.17.21",
    "@types/bcryptjs": "^2.4.6"
  }
}
