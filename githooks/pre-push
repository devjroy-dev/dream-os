# Pre-push hook: syntax-check every .js file changed in pushed commits.
# If any file fails node --check, the push is aborted.
FAILED=0
for f in $(git diff --name-only origin/main..HEAD | grep '\.js$'); do
  if [ -f "$f" ]; then
    if ! node --check "$f" 2>&1; then
      echo "❌ Syntax error in $f — push aborted."
      FAILED=1
    fi
  fi
done
if [ $FAILED -eq 1 ]; then
  echo ""
  echo "Fix syntax errors and try again."
  exit 1
fi
echo "✅ All changed .js files passed syntax check."
exit 0
